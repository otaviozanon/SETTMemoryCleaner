<local:View x:Class="SETTMemoryCleaner.MainWindow"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:local="clr-namespace:SETTMemoryCleaner"
            AllowsTransparency="True"
            Background="Transparent"
            BorderBrush="Transparent"
            BorderThickness="0"
            DataContext="{Binding MainViewModel, Source={StaticResource ViewModelLocator}}"
            FlowDirection="{Binding Path=(local:Localizer.Language).Direction}"
            FocusManager.FocusedElement="{Binding ElementName=Optimize}"
            FontSize="{Binding FontSize}"
            Foreground="{DynamicResource SecondaryForeground}"
            Icon="/SETTMemoryCleaner;component/Resources/Images/sett-icon.ico"
            MouseDown="OnWindowMouseDown"
            ResizeMode="NoResize"
            SizeToContent="WidthAndHeight"
            SnapsToDevicePixels="True"
            Title="{x:Static local:Constants+App.Title}"
            Topmost="{Binding AlwaysOnTop}"
            UseLayoutRounding="True"
            WindowStartupLocation="CenterScreen"
            WindowStyle="None">
    <!-- Window -->
    <Border Background="{DynamicResource PrimaryBackground}"
            BorderBrush="{DynamicResource PrimaryBorder}"
            BorderThickness="1"
            CornerRadius="12"
            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}, FallbackValue=True}">
        <StackPanel>
            <!-- Header -->
            <Grid Margin="16, 12, 16, 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"
                            KeyboardNavigation.TabNavigation="None"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Image RenderOptions.BitmapScalingMode="Fant"
                           RenderOptions.EdgeMode="Aliased"
                           Source="/SETTMemoryCleaner;component/Resources/Images/sett-icon.ico"
                           Height="18"
                           Width="18"
                           VerticalAlignment="Center" />
                    <TextBlock FontWeight="SemiBold"
                               FontSize="14"
                               Margin="8, 0, 0, 0"
                               Text="{Binding Title}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <!-- Help Button -->
                    <Button Background="Transparent" 
                            BorderBrush="Transparent" 
                            BorderThickness="0"
                            Click="OnHelpButtonClick"
                            Content="?"
                            Cursor="Arrow"
                            FontFamily="Arial"
                            Margin="10, 0, 5, 0"
                            PreviewMouseRightButtonDown="OnHelpButtonPreviewMouseRightButtonDown"
                            ToolTip="{Binding Path=(local:Localizer.Strings).Help}"
                            VerticalAlignment="Center"
                            Visibility="{Binding CompactMode, Converter={StaticResource InverseBooleanToVisibilityConverter}, FallbackValue={x:Static Visibility.Visible}}">
                        <Button.Resources>
                            <ContextMenu x:Key="HelpContextMenu">
                                <MenuItem Command="{Binding NavigateUriCommand}"
                                          CommandParameter="{x:Static local:Constants+App+Repository.AboutUri}"
                                          Header="{Binding Path=(local:Localizer.Strings).About}">
                                    <MenuItem.Icon>
                                        <Path Data="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38
                                                    0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13
                                                    -.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52
                                                    .28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12
                                                    0 0 .67-.21 2.2.82a7.59 7.59 0 012-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82
                                                    .44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48
                                                    0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"
                                              Fill="{DynamicResource SecondaryForeground}"
                                              Height="20"
                                              Margin="0"
                                              Stretch="Uniform"
                                              Width="20" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Click="OnResetSettingsToDefaultConfigurationClick"
                                          Header="{Binding Path=(local:Localizer.Strings).Reset}">
                                    <MenuItem.Icon>
                                        <Path Data="M12,4 C7.58,4 4,7.58 4,12 C4,16.42 7.58,20 12,20 C15.84,20 19.14,17.22 19.83,13.5 H17.83 C17.2,16.14 14.86,18 12,18 C8.69,18 6,15.31 6,12 C6,8.69 8.69,6 12,6 V10 L17,5 L12,0 V4 Z" 
                                              Fill="White"
                                              Height="20"
                                              Margin="0"
                                              Stretch="Uniform" 
                                              Width="20" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator Margin="0, 5, 0, 0" />
                                <MenuItem Click="OnDonateMenuItemClick"
                                          Header="{Binding Path=(local:Localizer.Strings).Donate}">
                                    <MenuItem.Icon>
                                        <Path Data="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41 0.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
                                              Fill="Red"
                                              Height="20"
                                              Margin="0"
                                              Stretch="Uniform"
                                              Width="20" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Button.Resources>
                    </Button>
                    <!-- Compact Mode Button -->
                    <ToggleButton Background="Transparent"
                                  BorderBrush="Transparent"
                                  BorderThickness="0"
                                  Click="OnCompactModeButtonClick"
                                  Cursor="Arrow"
                                  IsChecked="{Binding CompactMode}"
                                  Padding="0, -3, 0, 0"
                                  VerticalAlignment="Center">
                        <Grid Background="Transparent"                              
                              Margin="10, 3, 10, 0"
                              VerticalAlignment="Center">
                            <Path Data="{Binding Tag, RelativeSource={RelativeSource AncestorType={x:Type ToggleButton}, Mode=FindAncestor}}"
                                  Height="12"
                                  HorizontalAlignment="Center"
                                  Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type ToggleButton}, Mode=FindAncestor}}"
                                  StrokeThickness="2"
                                  VerticalAlignment="Center"
                                  Width="14" />
                        </Grid>
                        <ToggleButton.Resources>
                            <Style TargetType="{x:Type ToggleButton}" BasedOn="{StaticResource {x:Type ToggleButton}}">
                                <Style.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter Property="Tag" Value="M 0.5 0 L 5.5 5 L 10.5 0" />
                                        <Setter Property="ToolTip" Value="{Binding Path=(local:Localizer.Strings).Expand}" />
                                    </Trigger>
                                    <Trigger Property="IsChecked" Value="False">
                                        <Setter Property="Tag" Value="M 0.5 5 L 5.5 0 L 10.5 5" />
                                        <Setter Property="ToolTip" Value="{Binding Path=(local:Localizer.Strings).Collapse}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Resources>
                    </ToggleButton>
                    <!-- Minimize Button -->
                    <Button Background="Transparent" 
                            BorderBrush="Transparent" 
                            BorderThickness="0"
                            Click="OnMinimizeButtonClick"
                            Cursor="Arrow"
                            Padding="0, -3, 0, 0"
                            ToolTip="{Binding Path=(local:Localizer.Strings).Minimize}"
                            VerticalAlignment="Center">
                        <Grid Background="Transparent"
                              Height="12"
                              Margin="10, 3, 10, 0"                              
                              VerticalAlignment="Center">
                            <Path Data="M9,0 L8,1 8,1 8,1 0,1 0,1 z"
                                  HorizontalAlignment="Center"
                                  Stretch="None"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}, Mode=FindAncestor}}"
                                  StrokeThickness="3"
                                  VerticalAlignment="Center"
                                  Width="9" />
                        </Grid>
                    </Button>
                    <!-- Close Button -->
                    <Button Background="Transparent" 
                            BorderBrush="Transparent" 
                            BorderThickness="0"
                            Click="OnCloseButtonClick"
                            Cursor="Arrow"
                            Padding="0, -3, 0, 0"
                            ToolTip="{Binding Path=(local:Localizer.Strings).Close}"
                            VerticalAlignment="Center">
                        <Grid Background="Transparent"
                              Height="12"
                              Margin="10, 3, 10, 0"
                              VerticalAlignment="Center">
                            <Path Data="M0,0 L1,1 M0,1 L1,0"
                                  Height="10"
                                  HorizontalAlignment="Center"
                                  Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}, Mode=FindAncestor}}"
                                  StrokeThickness="2"
                                  VerticalAlignment="Center"
                                  Width="10" />
                        </Grid>
                    </Button>
                </StackPanel>
            </Grid>
            <!-- Content -->
            <Grid Margin="16, 10, 16, 0"
                  Visibility="{Binding CompactMode, Converter={StaticResource InverseBooleanToVisibilityConverter}, FallbackValue={x:Static Visibility.Visible}}"
                  x:Name="ContentGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="285" />
                    <ColumnDefinition Width="285" />
                    <ColumnDefinition Width="285" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <!-- Column 1: Settings -->
                <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
                        Background="#252525"
                        CornerRadius="8"
                        Margin="0, 0, 6, 0"
                        Padding="12, 10">
                    <StackPanel>
                    <!-- Settings -->
                    <GroupBox Header="{Binding Path=(local:Localizer.Strings).Settings}"
                              Margin="0, 0, 6, 0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0, 0, 0, 5">
                                <TextBlock FontSize="13" Margin="0, 0, 6, 0" Text="🌐" VerticalAlignment="Center" />
                                <ComboBox ItemsSource="{x:Static local:Localizer.Languages}"
                                          MouseRightButtonUp="OnComboBoxMouseRightButtonUp"
                                          SelectedValue="{Binding Language}"
                                          MinWidth="140" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0, 0, 0, 5">
                                <TextBlock FontSize="13" Margin="0, 0, 8, 0" Text="🗚" VerticalAlignment="Center" />
                                <Slider IsSnapToTickEnabled="True" Maximum="16" Minimum="12"
                                        Name="FontSizeSlider" TickFrequency="1"
                                        Value="{Binding FontSize}" Width="100" />
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding SettingItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Name}"
                                                  IsChecked="{Binding Value, Mode=TwoWay}"
                                                  IsEnabled="{Binding IsEnabled}"
                                                  Margin="0, 0, 0, 3" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </GroupBox>
                    </StackPanel>
                </Border>

                <!-- Column 2: Memory Areas + Tray Icon -->
                <Border Grid.Column="1" Grid.Row="0" Grid.RowSpan="2"
                        Background="#252525"
                        CornerRadius="8"
                        Margin="0, 0, 6, 0"
                        Padding="12, 10">
                    <StackPanel>
                    <!-- Memory Areas -->
                    <GroupBox Header="{Binding Path=(local:Localizer.Strings).MemoryAreas}"
                              Margin="0, 0, 6, 0">
                        <ItemsControl ItemsSource="{Binding MemoryAreaItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}"
                                              IsChecked="{Binding Value, Mode=TwoWay}"
                                              IsEnabled="{Binding IsEnabled}"
                                              Margin="0, 0, 0, 3" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </GroupBox>

                    <!-- Tray Icon -->
                    <GroupBox Header="{Binding Path=(local:Localizer.Strings).TrayIcon}"
                              Margin="0, 6, 6, 0">
                        <ItemsControl ItemsSource="{Binding TrayIconItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}"
                                              IsChecked="{Binding Value, Mode=TwoWay}"
                                              IsEnabled="{Binding IsEnabled}"
                                              Margin="0, 0, 0, 3" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </GroupBox>
                    </StackPanel>
                </Border>

                <!-- Column 3: Process Exclusion + Auto Optimization -->
                <Border Grid.Column="2" Grid.Row="0" Grid.RowSpan="2"
                        Background="#252525"
                        CornerRadius="8"
                        Margin="0, 0, 0, 0"
                        Padding="12, 10">
                    <StackPanel>
                    <!-- Process Exclusion List -->
                    <GroupBox Header="{Binding Path=(local:Localizer.Strings).ProcessExclusionList}"
                              Margin="0, 0, 0, 0">
                        <StackPanel>
                            <ScrollViewer Height="60" VerticalScrollBarVisibility="Auto" Margin="0, 0, 0, 3" x:Name="ProcessExclusionScrollViewer">
                                <ItemsControl ItemsSource="{Binding ProcessExclusionList}" Name="ProcessExclusionList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0, 0, 0, 2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Button Command="{Binding MainViewModel.RemoveProcessFromExclusionListCommand, Source={StaticResource ViewModelLocator}}"
                                                        CommandParameter="{Binding}"
                                                        Content="-"
                                                        Padding="5, 0"
                                                        ToolTip="{Binding Path=(local:Localizer.Strings).Remove}" />
                                                <TextBlock Grid.Column="1" Margin="4, 0, 0, 0" Text="{Binding}" VerticalAlignment="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox DropDownOpened="OnProcessesDropDownOpened"
                                          ItemsSource="{Binding Processes}"
                                          MouseRightButtonUp="OnComboBoxMouseRightButtonUp"
                                          Name="Processes"
                                          SelectedValue="{Binding SelectedProcess}" />
                                <Button Content="+" Grid.Column="1"
                                        Command="{Binding AddProcessToExclusionListCommand}"
                                        CommandParameter="{Binding ElementName=Processes, Path=Text}"
                                        Margin="4, 0, 0, 0"
                                        Padding="6, 0"
                                        ToolTip="{Binding Path=(local:Localizer.Strings).Add}" />
                            </Grid>
                        </StackPanel>
                    </GroupBox>

                    <!-- Auto Optimization -->
                    <GroupBox Header="{Binding Path=(local:Localizer.Strings).AutoOptimization}"
                              Margin="0, 6, 0, 0">
                        <StackPanel>
                            <TextBlock Text="{Binding AutoOptimizationMemoryIntervalDescription}" TextWrapping="Wrap" FontSize="11" />
                            <Slider IsSnapToTickEnabled="True"
                                    Margin="0, 6, 0, 6"
                                    Maximum="168"
                                    Minimum="0"
                                    Name="AutoOptimizationIntervalSlider"
                                    TickFrequency="1"
                                    Value="{Binding AutoOptimizationInterval}" />

                            <TextBlock Text="{Binding AutoOptimizationMemoryUsageDescription}" TextWrapping="Wrap" FontSize="11" Margin="0, 4, 0, 0" />
                            <Slider IsSnapToTickEnabled="True"
                                    Margin="0, 6, 0, 0"
                                    Maximum="100"
                                    Minimum="0"
                                    Name="AutoOptimizationMemoryUsageSlider"
                                    TickFrequency="1"
                                    ToolTip="{Binding AutoOptimizationMemoryUsageWarning}"
                                    Value="{Binding AutoOptimizationMemoryUsage}" />
                        </StackPanel>
                    </GroupBox>

                    <!-- Optimization Hotkey -->
                    <GroupBox Header="{Binding Path=(local:Localizer.Strings).OptimizationHotkey}"
                              Margin="0, 6, 0, 0"
                              Visibility="{Binding Computer.OperatingSystem.HasHotkeyManager, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue={x:Static Visibility.Collapsed}}">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox IsChecked="{Binding UseHotkey}" Margin="0, 0, 4, 0" />
                            <ComboBox DisplayMemberPath="Value"
                                      IsEnabled="{Binding UseHotkey}"
                                      ItemsSource="{Binding KeyboardModifiers}"
                                      MouseRightButtonUp="OnComboBoxMouseRightButtonUp"
                                      SelectedValue="{Binding OptimizationModifiers}"
                                      SelectedValuePath="Key"
                                      MinWidth="60" />
                            <TextBlock IsEnabled="{Binding UseHotkey}" Margin="4, 0" Text="+" VerticalAlignment="Center" />
                            <ComboBox IsEnabled="{Binding UseHotkey}"
                                      ItemsSource="{Binding KeyboardKeys}"
                                      MouseRightButtonUp="OnComboBoxMouseRightButtonUp"
                                      SelectedValue="{Binding OptimizationKey}"
                                      MinWidth="60" />
                        </StackPanel>
                    </GroupBox>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Physical Memory (full width) -->
            <GroupBox Header="{Binding PhysicalMemoryHeader}"
                      KeyboardNavigation.TabNavigation="None"
                      Margin="16, 8, 16, 0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Progress Bar -->
                            <ProgressBar BorderThickness="0"
                                         Grid.Row="0"
                                         Height="24"
                                         Maximum="100"
                                         Margin="0, 0, 0, 6"
                                         Minimum="0"
                                         Value="{Binding Computer.Memory.Physical.Used.Percentage}">
                                <ProgressBar.Template>
                                    <ControlTemplate>
                                        <Grid>
                                            <Border Background="{DynamicResource MemoryBarTrackBackground}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="5"
                                                    Name="PART_Track">
                                                <Grid>
                                                    <Border Background="{DynamicResource MemoryBarIndicatorBackground}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="5"
                                                            HorizontalAlignment="Left"
                                                            Name="PART_Indicator" />
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontWeight="SemiBold"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource SecondaryForeground}">
                                                        <Run Text="{Binding Computer.Memory.Physical.Used.Value, Converter={StaticResource StringFormatConverter}, ConverterParameter={}{0:0.#}, Mode=OneWay}" />
                                                        <Run Text=" " />
                                                        <Run Text="{Binding Computer.Memory.Physical.Used.Unit, Mode=OneWay}" />
                                                        <Run Text=" / " />
                                                        <Run Text="{Binding Computer.Memory.Physical.Total.Value, Converter={StaticResource StringFormatConverter}, ConverterParameter={}{0:0.#}, Mode=OneWay}" />
                                                        <Run Text=" " />
                                                        <Run Text="{Binding Computer.Memory.Physical.Total.Unit, Mode=OneWay}" />
                                                        <Run Text="  (" />
                                                        <Run Text="{Binding Computer.Memory.Physical.Used.Percentage, Mode=OneWay}" />
                                                        <Run Text="%)" />
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </ControlTemplate>
                                </ProgressBar.Template>
                            </ProgressBar>

                            <!-- Legend -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <Border Background="{DynamicResource MemoryBarIndicatorBackground}"
                                            BorderThickness="0"
                                            CornerRadius="2"
                                            Height="8"
                                            Margin="0, 0, 4, 0"
                                            VerticalAlignment="Center"
                                            Width="8" />
                                    <TextBlock Text="{Binding Path=(local:Localizer.Strings).Used}"
                                               FontSize="10"
                                               Opacity="0.7" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Border Background="{DynamicResource MemoryBarTrackBackground}"
                                            BorderThickness="0"
                                            CornerRadius="2"
                                            Height="8"
                                            Margin="0, 0, 4, 0"
                                            VerticalAlignment="Center"
                                            Width="8" />
                                    <TextBlock Text="{Binding Path=(local:Localizer.Strings).Free}"
                                               FontSize="10"
                                               Opacity="0.7" />
                                </StackPanel>
                            </Grid>
                        </Grid>
            </GroupBox>

            <!-- Virtual Memory (full width) -->
            <GroupBox Header="{Binding VirtualMemoryHeader}"
                      KeyboardNavigation.TabNavigation="None"
                      Margin="16, 8, 16, 0"
                      Visibility="{Binding ShowVirtualMemory, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue={x:Static Visibility.Collapsed}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Progress Bar -->
                            <ProgressBar BorderThickness="0"
                                         Grid.Row="0"
                                         Height="24"
                                         Maximum="100"
                                         Margin="0, 0, 0, 6"
                                         Minimum="0"
                                         Value="{Binding Computer.Memory.Virtual.Used.Percentage}">
                                <ProgressBar.Template>
                                    <ControlTemplate>
                                        <Grid>
                                            <Border Background="{DynamicResource MemoryBarTrackBackground}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="5"
                                                    Name="PART_Track">
                                                <Grid>
                                                    <Border Background="{DynamicResource MemoryBarIndicatorBackground}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="5"
                                                            HorizontalAlignment="Left"
                                                            Name="PART_Indicator" />
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontWeight="SemiBold"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource SecondaryForeground}">
                                                        <Run Text="{Binding Computer.Memory.Virtual.Used.Value, Converter={StaticResource StringFormatConverter}, ConverterParameter={}{0:0.#}, Mode=OneWay}" />
                                                        <Run Text=" " />
                                                        <Run Text="{Binding Computer.Memory.Virtual.Used.Unit, Mode=OneWay}" />
                                                        <Run Text=" / " />
                                                        <Run Text="{Binding Computer.Memory.Virtual.Total.Value, Converter={StaticResource StringFormatConverter}, ConverterParameter={}{0:0.#}, Mode=OneWay}" />
                                                        <Run Text=" " />
                                                        <Run Text="{Binding Computer.Memory.Virtual.Total.Unit, Mode=OneWay}" />
                                                        <Run Text="  (" />
                                                        <Run Text="{Binding Computer.Memory.Virtual.Used.Percentage, Mode=OneWay}" />
                                                        <Run Text="%)" />
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </ControlTemplate>
                                </ProgressBar.Template>
                            </ProgressBar>

                            <!-- Legend -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <Border Background="{DynamicResource MemoryBarIndicatorBackground}"
                                            BorderThickness="0"
                                            CornerRadius="2"
                                            Height="8"
                                            Margin="0, 0, 4, 0"
                                            VerticalAlignment="Center"
                                            Width="8" />
                                    <TextBlock Text="{Binding Path=(local:Localizer.Strings).Used}"
                                               FontSize="10"
                                               Opacity="0.7" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Border Background="{DynamicResource MemoryBarTrackBackground}"
                                            BorderThickness="0"
                                            CornerRadius="2"
                                            Height="8"
                                            Margin="0, 0, 4, 0"
                                            VerticalAlignment="Center"
                                            Width="8" />
                                    <TextBlock Text="{Binding Path=(local:Localizer.Strings).Free}"
                                               FontSize="10"
                                               Opacity="0.7" />
                                </StackPanel>
                            </Grid>
                        </Grid>
            </GroupBox>

            <!-- Optimize Button -->
            <Grid Margin="16, 8, 16, 14">
                <!-- Optimize -->
                <Button Command="{Binding OptimizeCommand}"
                        Content="{Binding Path=(local:Localizer.Strings).Optimize}"
                        KeyboardNavigation.TabIndex="0"
                        Margin="0, 0, 0, 0"
                        Name="Optimize"
                        Padding="0"
                        Height="36"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Style="{StaticResource ButtonWithFocusFadeStyle}"
                        TabIndex="0" />
                <Grid Height="Auto"
                      Margin="0, 0, 0, 0"
                      Visibility="{Binding IsOptimizationRunning, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue={x:Static Visibility.Hidden}}">
                    <ProgressBar BorderBrush="{DynamicResource Accent}"
                                 BorderThickness="1"
                                 FontWeight="Normal"
                                 HorizontalContentAlignment="Center"
                                 Maximum="{Binding OptimizationProgressTotal}"
                                 Minimum="0"
                                 Height="36"
                                 Value="{Binding OptimizationProgressValue}"
                                 VerticalAlignment="Stretch"
                                 VerticalContentAlignment="Center">
                        <ProgressBar.Template>
                            <ControlTemplate>
                                <Grid VerticalAlignment="Stretch">
                                    <Border Background="{DynamicResource SecondaryBackground}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6"
                                            Name="PART_Track"
                                            VerticalAlignment="Stretch" />
                                    <Border Background="{DynamicResource Accent}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6"
                                            HorizontalAlignment="Left"
                                            Name="PART_Indicator"
                                            VerticalAlignment="Stretch" />
                                </Grid>
                            </ControlTemplate>
                        </ProgressBar.Template>
                    </ProgressBar>
                    <TextBlock FontWeight="Normal"
                               Foreground="{DynamicResource SecondaryForeground}"
                               HorizontalAlignment="Left"
                               Margin="10, 0, 5, 0"
                               Text="{Binding OptimizationProgressStep}"
                               VerticalAlignment="Center" />
                    <StackPanel HorizontalAlignment="Right"
                                Orientation="Horizontal"
                                Margin="5, 0, 10, 0"
                                VerticalAlignment="Center">
                        <TextBlock FontWeight="Normal"
                                   Foreground="{DynamicResource SecondaryForeground}"
                                   Text="{Binding OptimizationProgressValue}"
                                   VerticalAlignment="Center" />
                        <TextBlock FontWeight="Normal"
                                   Foreground="{DynamicResource SecondaryForeground}"
                                   Text=" / "
                                   VerticalAlignment="Center" />
                        <TextBlock FontWeight="Normal"
                                   Foreground="{DynamicResource SecondaryForeground}"
                                   Text="{Binding OptimizationProgressTotal}"
                                   VerticalAlignment="Center" />
                        <TextBlock FontWeight="Normal"
                                   Foreground="{DynamicResource SecondaryForeground}"
                                   Text=" ("
                                   VerticalAlignment="Center" />
                        <TextBlock FontWeight="Normal"
                                   Foreground="{DynamicResource SecondaryForeground}"
                                   Text="{Binding OptimizationProgressPercentage}"
                                   VerticalAlignment="Center" />
                        <TextBlock FontWeight="Normal"
                                   Foreground="{DynamicResource SecondaryForeground}"
                                   Text="%)"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Grid>
        </StackPanel>
    </Border>
</local:View>